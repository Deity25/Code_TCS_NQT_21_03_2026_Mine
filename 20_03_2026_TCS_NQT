Q. Gym Membership. If 0 month print invalid input and if 1 month then print 2000 and for 3 print 5000 and for 5 print 9000 and finally for 7 print 15000 rupees.

import java.util.*;
class Main {
public static void main(String[]args){
Scanner sc = new Scanner(System.in);
int a = sc.nextInt();
switch(a){
case 1 -> System.out.println("2000");
case 3 -> System.out.println("5000");
case 5 -> System.out.println("9000");
case 7 -> System.out.println("15000");
case 0 -> System.out.println("Invalid Input");
}
}
}


