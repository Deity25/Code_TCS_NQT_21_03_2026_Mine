class Main{
  public static void main(String[]args){
    int a = 1234;
    int start = a;
    int end = 0;
    while(start>0){
      int digit = start % 10;
      end = end * 10 + digit;
      start = start / 10;
    }
    System.out.println(end);
  }
}

int a = 1234;
String str = Integer.toString(a);
String rev = "";
for(int i = str.length()-1; i>=0; i--){
rev = rev + str.charAt(i);
}
System.out.println(rev);
