class Main{
  public static void main(String[]args){
    int a = 11211;
    int start = a;
    int end = 0;
    if (a < 0) {
            System.out.println("Not Palindrome");
            return;
        }
    while(a>0){
      int digit = a % 10;
      end = end * 10 + digit;
      a = a / 10;
    }
    if(start == end){
            System.out.println(start + " " + "Palindrome");

    }else{
        System.out.println("Not Palindrome");
    }
  }
}
