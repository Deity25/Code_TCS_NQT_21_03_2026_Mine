import java.util.Scanner;

public class SoldierPlacement {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        
        // Input: N (soldiers), r (ranks), L (last soldier's rank)
        if (!sc.hasNextInt()) return;
        int N = sc.nextInt();
        int r = sc.nextInt();
        int L = sc.nextInt();
        
        System.out.println(countSequences(N, r, L));
    }

    public static long countSequences(int N, int r, int L) {
        // Base Case: If there's only one soldier, they must be rank 1.
        if (N == 1) {
            return (L == 1) ? 1 : 0;
        }
        
        // If there's only 1 rank available but more than 1 soldier, 
        // they can't be placed without having adjacent same ranks.
        if (r < 2 && N > 1) {
            return 0;
        }

        // dp[i][j] stores number of valid sequences of length i ending in rank j.
        // Using long to prevent overflow for larger N.
        long[][] dp = new long[N + 1][r + 1];

        // The first soldier's rank is always 1.
        dp[1][1] = 1;

        for (int i = 2; i <= N; i++) {
            long totalPrevWays = 0;
            for (int k = 1; k <= r; k++) {
                totalPrevWays += dp[i - 1][k];
            }

            for (int j = 1; j <= r; j++) {
                // Number of ways to end at rank j at position i is 
                // (Total ways at i-1) minus (ways that ended at rank j at i-1).
                dp[i][j] = totalPrevWays - dp[i - 1][j];
            }
        }

        return dp[N][L];
    }
}


