import java.util.*;
class MyClass {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int price = sc.nextInt();
        double discount = 0;

        if (price < 0) {
            System.out.println("Negative so Error");
            return; // Stops the program immediately
        } else if (price <= 1000) {
            discount = 0.05;
        } else if (price <= 5000) {
            discount = 0.10;
        } else {
            discount = 0.15;
        }

        System.out.println((int)(price - (price * discount)));
    }
}

